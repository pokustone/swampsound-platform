rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Galerie — admin nahrává, členové čtou
    match /gallery/{eventId}/{filename} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // Audio — admin/členové nahrávají, členové čtou
    match /audio/{filename} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }
  }
}
